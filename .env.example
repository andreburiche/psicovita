APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080

# Porta do `php artisan serve` (padrão do Laravel é 8000). Ajuste se precisar.
SERVER_PORT=8080

# pt_BR para mensagens de validação e interface em português (ver lang/pt_BR/)
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Com valor >1 use: php artisan serve --no-reload (senão o servidor PHP ignora workers extra).
PHP_CLI_SERVER_WORKERS=1

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=psiconecta
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Opcional: logo em public/ (padrão images/Logo.png)
# APP_LOGO=images/Logo.png
# APP_LOGO_ALT="PsicoVita — Cuidar da mente é transformar vidas."

VITE_APP_NAME="${APP_NAME}"
# Com Node instalado: npm ci && npm run build (gera public/build/manifest.json).
# Em APP_ENV=local, sem build/hot, a UI usa fallback CDN (Tailwind + Alpine) para não quebrar.

# PsiConecta — LGPD / conformidade
LGPD_DPO_NAME="Encarregado de Proteção de Dados"
LGPD_DPO_EMAIL=privacidade@example.com
LGPD_COMPANY_NAME="${APP_NAME}"
LGPD_RESPONSE_SLA_DAYS=15
LGPD_DSR_RETENTION_DAYS=730
LGPD_AUDIT_RETENTION_DAYS=365
LGPD_DPIA_AI_REVIEW_DATE=
LGPD_DPIA_AI_RISK_LEVEL=moderado
# Export CSV de auditoria: e-mail do utilizador omitido por padrão (LGPD)
LGPD_AUDIT_EXPORT_INCLUDE_USER_EMAIL=false
LGPD_AUDIT_EXPORT_INCLUDE_IP_ADDRESS=true
# Pós-migrate em bases existentes:
# php artisan psiconecta:encrypt-cpf
# php artisan psiconecta:encrypt-patient-contacts
# php artisan psiconecta:encrypt-user-emails
# php artisan psiconecta:encrypt-message-bodies

# PsiConecta — pagamentos (Asaas)
ASAAS_ENABLED=false
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=
ASAAS_SPLIT_ENABLED=false
ASAAS_PLATFORM_WALLET_ID=
ASAAS_CONNECT_ENABLED=false
ASAAS_CONNECT_POSTAL_CODE=
ASAAS_CONNECT_ADDRESS=
ASAAS_CONNECT_ADDRESS_NUMBER=
ASAAS_CONNECT_PROVINCE=
# Sem conta Asaas: QR estático (ficheiro em public/, ex. imagem exportada do seu banco)
ASAAS_PIX_FALLBACK_IMAGE=images/pix-fallback.svg
ASAAS_PIX_FALLBACK_PAYLOAD=
ASAAS_PIX_FALLBACK_BANK=
PAYMENT_PLATFORM_FEE_PERCENT=10
SUBSCRIPTION_TRIAL_DAYS=14
SUBSCRIPTION_EXPIRING_SOON_DAYS=3
SUBSCRIPTION_ANNUAL_DISCOUNT_PERCENT=17
PAYMENT_DEFAULT_SESSION_AMOUNT=150
PAYMENT_AUTO_CHARGE_ON_SESSION=true
PAYMENT_PATIENT_NOTIFICATIONS_ENABLED=true
PAYMENT_PATIENT_REMINDER_DAYS=3
PAYMENT_PROFESSIONAL_NOTIFICATIONS_ENABLED=true

CHATBOT_ENABLED=true
CHATBOT_WIDGET_ENABLED=true
CHATBOT_WHATSAPP_ENABLED=false
CHATBOT_AI_ENABLED=false

CLINIC_MAX_TEAM_MEMBERS=5
CLINIC_INVITATION_EXPIRES_DAYS=7

# PsiConecta — WhatsApp (meta = Cloud API | evolution = Evolution API)
WHATSAPP_ENABLED=false
WHATSAPP_DRIVER=meta
WHATSAPP_DEFAULT_CALLING_CODE=55
# Meta Cloud API
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Evolution API (WHATSAPP_DRIVER=evolution)
EVOLUTION_API_URL=http://127.0.0.1:8082
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=psiconecta
EVOLUTION_WEBHOOK_TOKEN=

# Login social (Google / Facebook) — deixe vazio para ocultar os botões
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"
